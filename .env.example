# Copy to .env and fill in.

# Sui signer for the relayer — MUST hold the RelayerCap (the deployer wallet 0x0c8b…).
# Bech32 form, starts with "suiprivkey1…". Export: sui keytool export --key-identity <alias>
OPERATOR_SECRET_KEY=suiprivkey1...

# x25519 secret (hex, 64 chars) whose public key is stored on-chain as
# Config.relayer_encryption_key. Generated + set on-chain by `npm run set-key`.
RELAYER_X25519_SECRET=

# Anthropic API key for the Claude analyzer. If unset, the relayer falls back to the
# offline rule-based analyzer.
ANTHROPIC_API_KEY=

# API auth: if set, write (POST) routes require this value in the `x-api-key` header.
# Leave unset for local dev/demo (writes are then unauthenticated — a warning is logged).
RELAYER_API_KEY=

# Optional overrides.
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# POLL_INTERVAL_MS=4000
# PORT=8787
# PUBLIC_BASE_URL=http://localhost:8787   # used to build escalation approve/reject/review links
# RATE_LIMIT_MAX=120                       # per-IP requests per window
# RATE_LIMIT_WINDOW_MS=60000
